<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <com.jingtian.demoapp.main.footcurve.FootCurveView
        android:id="@+id/footCurveView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"/>

    <com.jingtian.demoapp.main.widget.PopupMenuView
        android:id="@+id/pop_up_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        app:popUpMenuBottomView="@layout/panel_popup_foot_curve_config"/>

    <SeekBar
        android:id="@+id/seekBarT"
        android:layout_marginVertical="20dp"
        android:layout_marginHorizontal="16dp"
        android:paddingVertical="6dp"
        android:layout_gravity="bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</FrameLayout>